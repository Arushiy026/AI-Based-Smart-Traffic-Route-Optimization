from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from pydantic import BaseModel
import uvicorn
import os
import sys

# Add root folder to sys.path
base_dir = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
sys.path.append(base_dir)

from backend.services.simulation_engine import SimulationEngine
from backend.api.data_generator import get_graph_data

app = FastAPI(title="Smart Traffic API")

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

# Initialize engine globally
engine = SimulationEngine()

# Response Models
class RouteRequest(BaseModel):
    source: str
    destination: str
    mode: str = "normal" # normal | emergency
    preference: str = "balanced" # fastest | least_traffic | balanced

class BlockRequest(BaseModel):
    source: str
    target: str
    action: str # block | unblock

class RippleRequest(BaseModel):
    source: str
    intensity: float = 5.0

@app.get("/graph")
def get_graph():
    """Return the static mock data representing the map"""
    return get_graph_data()

@app.post("/route")
def get_route(req: RouteRequest):
    routes, primary_time = engine.find_route(req.source, req.destination, mode=req.mode, preference=req.preference)
    if not routes:
        raise HTTPException(status_code=404, detail="No route found between these points.")
        
    return {
        "routes": routes,
        "primary_time": primary_time
    }

@app.post("/compare")
def compare_algorithms(req: RouteRequest):
    result = engine.compare_algorithms(req.source, req.destination)
    if result["dijkstra"]["path"] is None:
         raise HTTPException(status_code=404, detail="No path found.")
    return result

@app.post("/simulate-block")
def simulate_block(req: BlockRequest):
    if req.action == "block":
        engine.simulate_block(req.source, req.target)
    else:
        engine.resolve_block(req.source, req.target)
    return {"status": "success", "action": req.action, "edge": f"{req.source}->{req.target}"}
    
@app.post("/simulate-ripple")
def simulate_ripple(req: RippleRequest):
    engine.apply_ripple_effect(req.source, req.intensity)
    return {"status": "success", "ripple_applied": req.source}

if __name__ == "__main__":
    uvicorn.run("main:app", host="0.0.0.0", port=8000, reload=True)

import os
import sys

base_dir = os.path.dirname(os.path.dirname(os.path.dirname(__file__)))
sys.path.append(base_dir)

from backend.algorithms.graph_engine import GraphEngine, RouteNode, RouteEdge
from backend.api.data_generator import NODES, EDGES
from ml.train_model import TrafficPredictor
from datetime import datetime

class SimulationEngine:
    def __init__(self):
        self.graph = GraphEngine()
        self.predictor = TrafficPredictor()
        self.blocked_edges = set() # Set of tuples (source, target)
        self.load_graph()

    def load_graph(self):
        self.graph = GraphEngine()
        for n in NODES:
            self.graph.add_node(RouteNode(n['id'], n['lat'], n['lng']))
            
        current_hour = datetime.now().hour
        
        for e in EDGES:
            if (e['source'], e['target']) in self.blocked_edges:
                continue
                
            # predict traffic using the ML engine
            pred_traffic = self.predictor.predict(current_hour, e['traffic'])
            self.graph.add_edge(RouteEdge(
                source=e['source'],
                target=e['target'],
                distance=e['distance'],
                traffic=e['traffic'],
                predicted_traffic=pred_traffic
            ))

    def simulate_block(self, source, target):
        """Temporarily marks an edge as completely blocked (removed)"""
        self.blocked_edges.add((source, target))
        self.load_graph() # completely reconstruct graph
        
    def resolve_block(self, source, target):
        if (source, target) in self.blocked_edges:
            self.blocked_edges.remove((source, target))
            self.load_graph()
            
    def apply_ripple_effect(self, congestion_source_id, intensity=5.0):
        """If a node is heavily congested, ripple traffic penalties to neighbors"""
        # Get neighbors up to 2 hops
        affected_nodes = self.graph.bfs_traversal(congestion_source_id, hops=2)
        
        # Increase predicted traffic for edges originating from affected nodes
        for node_id in affected_nodes:
            if node_id in self.graph.adjacency_list:
                for edge in self.graph.adjacency_list[node_id]:
                    # Decay intensity slightly if we wanted to be more realistic, 
                    # but simple flat modifier for demo purposes
                    edge.predicted_traffic = min(10.0, edge.predicted_traffic + intensity)
                    
    def find_route(self, source, target, mode="normal", preference="balanced"):
        alpha = 1.0
        beta = 1.0
        
        if mode == "emergency":
            # Emergency routing minimizes traffic weight
            alpha = 0.2
            beta = 0.0
            
        paths, costs = self.graph.yens_k_shortest_paths(source, target, K=5, alpha=alpha, beta=beta)
        if not paths:
            return [], float('inf')
            
        analyzed_routes = []
        for path in paths:
            total_dist = 0
            total_traffic = 0
            
            for i in range(len(path)-1):
                u, v = path[i], path[i+1]
                edge = next((e for e in self.graph.adjacency_list[u] if e.target == v), None)
                if edge:
                    total_dist += edge.distance
                    total_traffic += (edge.traffic + edge.predicted_traffic)
                    
            # estimated time: base speed 40km/hr (0.66 km/min), traffic slows it down
            base_time = (total_dist / 40.0) * 60 # minutes
            traffic_penalty = (total_traffic / len(path)) * 2 # simple model
            estimated_time = round(base_time + traffic_penalty, 2)
            
            # calculate Score based on preference: Score = α(distance) + β(traffic) + γ(time)
            # lower score is better
            p_alpha, p_beta, p_gamma = 1.0, 1.0, 1.0 # balanced
            if preference == "fastest":
                p_alpha, p_beta, p_gamma = 0.5, 0.5, 2.0
            elif preference == "least_traffic":
                p_alpha, p_beta, p_gamma = 0.5, 2.0, 0.5
                
            score = p_alpha * total_dist + p_beta * total_traffic + p_gamma * estimated_time
            
            analyzed_routes.append({
                "path": path,
                "distance": round(total_dist, 2),
                "traffic_cost": round(total_traffic, 2),
                "estimated_time": estimated_time,
                "score": score
            })
            
        # sort by score
        analyzed_routes.sort(key=lambda x: x["score"])
        top_routes = analyzed_routes[:3]
        
        # Generate XAI explanation
        if len(top_routes) > 1:
            best = top_routes[0]
            alt = top_routes[1]
            time_saved = round(alt["estimated_time"] - best["estimated_time"], 1)
            traffic_diff = alt["traffic_cost"] - best["traffic_cost"]
            
            if mode == "emergency":
                 best["explanation"] = f"Emergency routing prioritized. Time to destination: {best['estimated_time']} mins."
                 for i in range(1, len(top_routes)):
                     top_routes[i]["explanation"] = "Alternative path."
            else:
                 if time_saved > 0 and traffic_diff > 0:
                     best["explanation"] = f"Recommended: Saves {time_saved} mins and avoids {round(traffic_diff,1)} congestion units vs alternative."
                 elif time_saved > 0:
                     best["explanation"] = f"Recommended: This is the fastest route, saving {time_saved} mins."
                 elif traffic_diff > 0:
                     best["explanation"] = f"Recommended: Avoids higher congestion zones, prioritizing a smoother drive."
                 else:
                     best["explanation"] = f"Recommended: Optimal balance of distance, time, and traffic based on your preference."
                     
                 for i in range(1, len(top_routes)):
                     top_routes[i]["explanation"] = f"Alternative route."
        elif len(top_routes) == 1:
             top_routes[0]["explanation"] = "This is the only viable route available."
            
        return top_routes, top_routes[0]["estimated_time"]

    def compare_algorithms(self, source, target):
        import time
        # Dijkstra
        start_dijk = time.perf_counter()
        d_path, d_dist = self.graph.dijkstra(source, target)
        dijkstra_time = time.perf_counter() - start_dijk
        
        # A*
        start_a = time.perf_counter()
        a_path, a_dist = self.graph.a_star(source, target)
        astar_time = time.perf_counter() - start_a
        
        return {
            "dijkstra": {
                "execution_ms": dijkstra_time * 1000,
                "cost": d_dist,
                "path": d_path
            },
            "astar": {
                "execution_ms": astar_time * 1000,
                "cost": a_dist,
                "path": a_path
            }
        }

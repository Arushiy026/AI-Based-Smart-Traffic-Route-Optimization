.app-shell {
  display: grid;
  grid-template-columns: 380px 1fr;
  height: 100vh;
  background: #05070d;
  color: #e2e8f0;
}

.panel {
  overflow-y: auto;
  padding: 16px;
  border-right: 1px solid #1f2937;
  background: #0b1220;
}

.panel h1 {
  margin: 0 0 8px;
  font-size: 22px;
  color: #f8fafc;
}

.panel h2 {
  margin: 0 0 8px;
  font-size: 16px;
  color: #cbd5e1;
}

.panel section {
  background: linear-gradient(145deg, #111827, #0b1220);
  border: 1px solid #243244;
  border-radius: 8px;
  padding: 12px;
  margin-bottom: 12px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.28);
}

.panel label {
  display: block;
  margin: 8px 0 4px;
  font-weight: 600;
  font-size: 13px;
}

.panel select,
.panel input,
.panel button {
  width: 100%;
  box-sizing: border-box;
  padding: 8px;
  border: 1px solid #334155;
  border-radius: 6px;
  background: #0f172a;
  color: #e2e8f0;
}

.panel button {
  background: #2563eb;
  color: #fff;
  border: none;
  cursor: pointer;
  margin-top: 8px;
}

.panel button:hover {
  background: #1d4ed8;
}

.panel button:disabled {
  opacity: 0.65;
  cursor: not-allowed;
}

.status {
  color: #93c5fd;
  margin-bottom: 12px;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.kpi-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.kpi-card {
  background: #020617;
  border: 1px solid #1e293b;
  border-radius: 8px;
  padding: 8px;
}

.kpi-card span {
  display: block;
  font-size: 12px;
  color: #94a3b8;
}

.kpi-card strong {
  font-size: 18px;
  color: #f8fafc;
}

.route-card {
  border: 1px solid #1e293b;
  border-radius: 6px;
  padding: 8px;
  margin-top: 8px;
  background: #020617;
}

.route-card p {
  margin: 4px 0;
  font-size: 13px;
}

.route-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.tag {
  display: inline-block;
  font-size: 11px;
  padding: 2px 8px;
  border-radius: 999px;
  background: #334155;
  color: #e2e8f0;
}

.tag.recommend {
  background: #14532d;
  color: #bbf7d0;
}

.comparison-card {
  border-radius: 8px;
  border: 1px solid #334155;
  padding: 10px;
  margin-top: 8px;
  background: #0f172a;
}

.comparison-card.risk {
  border-left: 4px solid #ef4444;
}

.comparison-card.safe {
  border-left: 4px solid #22c55e;
}

.insight-item {
  margin: 6px 0;
  color: #cbd5e1;
}

.map-wrap {
  width: 100%;
  height: 100%;
}

.map {
  width: 100%;
  height: 100%;
  filter: brightness(0.85) saturate(0.9);
}

@media (max-width: 1024px) {
  .app-shell {
    grid-template-columns: 1fr;
    grid-template-rows: auto 60vh;
  }
}
